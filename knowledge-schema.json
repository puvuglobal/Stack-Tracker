      "recommended": {
        "frontend": "Modular or microfrontends if needed",
        "backend": "Service-oriented",
        "structure": "Team autonomy per domain"
      }
    },
    "enterprise": {
      "maxDevs": 100,
      "recommended": {
        "frontend": "Microfrontends",
        "backend": "Microservices",
        "structure": "Full separation, platform team"
      }
    }
  },

  # ============================================================================
  # DECISION TREES
  # ============================================================================
  "decisionTree": {
    "frontend": [
      {
        "question": "Is the site mostly static?",
        "yes": "static_pages",
        "no": "Continue"
      },
      {
        "question": "Does the product require high interactivity?",
        "yes": "spa",
        "no": "ssr"
      },
      {
        "question": "Does SEO matter?",
        "yes": "ssr",
        "no": "spa"
      },
      {
        "question": "Do you support multiple client apps?",
        "yes": "bff",
        "no": "Continue"
      },
      {
        "question": "How many engineers?",
        "lessThan20": "modular_monolith",
        "20to200": "strong_modular",
        "moreThan200": "microfrontends"
      }
    ],
    "backend": [
      {
        "question": "Do you need full backend control?",
        "yes": "Continue",
        "no": "supabase_or_firebase"
      },
      {
        "question": "What language preference?",
        "javascript": ["express", "nestjs", "nextjs"],
        "python": ["django", "fastapi"],
        "php": ["laravel"],
        "go": ["gin", "fiber"]
      },
      {
        "question": "Scale requirements?",
        "small": "monolith",
        "large": "services"
      }
    ],
    "database": [
      {
        "question": "Is data relational?",
        "yes": "postgres",
        "no": "Continue"
      },
      {
        "question": "Need flexible schemas?",
        "yes": "mongodb",
        "no": "Continue"
      },
      {
        "question": "Need caching?",
        "yes": "redis"
      },
      {
        "question": "Need search?",
        "yes": "elasticsearch_or_algolia"
      }
    ]
  },

  # ============================================================================
  # MODULE GENERATION RULES
  # ============================================================================
  "moduleRules": {
    "auth": {
      "trigger": "feature_authentication",
      "generate": ["login", "register", "logout", "password_reset", "session_management"]
    },
    "billing": {
      "trigger": "feature_payments",
      "generate": ["checkout", "subscriptions", "invoices", "webhooks_handler", "usage_tracking"]
    },
    "orders": {
      "trigger": "productType_marketplace OR productType_ecommerce",
      "generate": ["create", "read", "update", "cancel", "status_tracking"]
    },
    "inventory": {
      "trigger": "productType_marketplace OR productType_ecommerce",
      "generate": ["stock_management", "reservations", "low_stock_alerts"]
    },
    "messaging": {
      "trigger": "feature_realtime OR productType_social",
      "generate": ["send", "receive", "threads", "read_status"]
    },
    "notifications": {
      "trigger": "feature_realtime OR productType_social",
      "generate": ["push", "email", "in_app", "preferences"]
    },
    "search": {
      "trigger": "feature_search",
      "generate": ["query", "filters", "sorting", "autocomplete"]
    },
    "media": {
      "trigger": "dataType_images OR dataType_video OR dataType_audio",
      "generate": ["upload", "process", "transform", "cdn_delivery"]
    },
    "analytics": {
      "trigger": "feature_analytics OR productType_saas",
      "generate": ["track_event", "dashboard", "export", "cohorts"]
    },
    "admin": {
      "trigger": "productType_internal",
      "generate": ["user_management", "settings", "audit_log", "reports"]
    }
  ,
  "variables": [
    {
      "id": "v001",
      "name": "product_type",
      "category": "Product",
      "description": "Type of product to build (marketplace, saas, social, ecommerce, internal, content, mobile_first)",
      "type": "enum",
      "options": ["marketplace", "saas", "social", "ecommerce", "internal", "content", "mobile_first"],
      "dependencies": []
    },
    {
      "id": "v002",
      "name": "client_architecture",
      "category": "Client",
      "description": "Primary client architecture (web/ios/android/desktop/public_api)",
      "type": "enum",
      "options": ["web", "ios", "android", "desktop", "public_api"],
      "dependencies": ["v001"]
    },
    {
      "id": "v003",
      "name": "data_types",
      "category": "Data",
      "description": "Data types involved (images, video, audio, documents, realtime)",
      "type": "enum",
      "options": ["images", "video", "audio", "documents", "realtime"],
      "dependencies": ["v001"]
    }
  ]
}
