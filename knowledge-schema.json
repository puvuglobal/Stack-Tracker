# StackTracker Knowledge Schema
# Extracted from Data supporting repo.txt
# Every variable, technology, concept with descriptions and decision logic

{
  "metadata": {
    "version": "1.0",
    "source": "StackTracker Decision Engine",
    "purpose": "Comprehensive tech stack knowledge base for SaaS architecture decisions"
  },

  # ============================================================================
  # 1. PRODUCT TYPE - Defines core interaction patterns and required modules
  # ============================================================================
  "productTypes": {
    "marketplace": {
      "description": "Platform connecting buyers and sellers, enabling transactions",
      "requires": ["payments", "search", "inventory", "orders", "user_profiles", "analytics", "messaging", "reviews"],
      "modules": ["auth", "billing", "orders", "inventory", "search", "messaging", "analytics", "notifications"],
      "archImplications": "SSR + SPA hybrid for SEO + dashboards, BFF pattern for multiple clients"
    },
    "saas": {
      "description": "Software as a service - subscription-based application",
      "requires": ["auth", "billing", "dashboard", "settings", "multi_tenant"],
      "modules": ["auth", "billing", "dashboard", "settings", "teams", "webhooks", "analytics"],
      "archImplications": "SPA for rich dashboards, modular monolith for team scale"
    },
    "social": {
      "description": "Social platform with user-generated content and interactions",
      "requires": ["feeds", "notifications", "realtime", "content_moderation", "media"],
      "modules": ["auth", "posts", "comments", "likes", "follows", "messages", "notifications", "media"],
      "archImplications": "Realtime essential, CDNs for media, BFF for multiple clients"
    },
    "ecommerce": {
      "description": "Online store for products/services sales",
      "requires": ["products", "cart", "checkout", "payments", "inventory", "shipping"],
      "modules": ["auth", "products", "cart", "checkout", "payments", "inventory", "shipping", "orders", "analytics"],
      "archImplications": "SSR for product pages (SEO), SPA for checkout, caching critical"
    },
    "internal": {
      "description": "Internal business tool/enterprise application",
      "requires": ["auth", "admin", "reporting", "workflows"],
      "modules": ["auth", "admin", "dashboard", "reports", "workflows", "audit"],
      "archImplications": "SPA acceptable (no SEO), focus on data density, can use heavier frameworks"
    },
    "content": {
      "description": "Content-focused site - blogs, docs, portfolios",
      "requires": ["cms", "seo", "media"],
      "modules": ["auth", "content", "media", "comments", "seo"],
      "archImplications": "SSG/ISR ideal for performance, minimal JavaScript"
    },
    "mobile_first": {
      "description": "Mobile-dominant application",
      "requires": ["mobile_responsive", "offline", "push_notifications"],
      "modules": ["auth", "core_features", "offline_sync", "push"],
      "archImplications": "PWA or native, API-first design, offline support"
    }
  },

  # ============================================================================
  # 2. CLIENT ARCHITECTURE - Defines frontend needs and API patterns
  # ============================================================================
  "clients": {
    "web": {
      "description": "Web browser application",
      "tech": "Next.js/React/Vue/Svelte",
      "implies": ["responsive", "cross_browser"],
      "conditionalQuestions": ["platform_mobile", "desktop_apps"]
    },
    "ios": {
      "description": "Apple iOS native app",
      "tech": "Swift/SwiftUI, React Native, Expo",
      "implies": ["apple_developer", "push_notifications"],
      "conditionalQuestions": ["xcode_required"]
    },
    "android": {
      "description": "Google Android native app",
      "tech": "Kotlin, React Native, Expo",
      "implies": ["google_play", "push_notifications"],
      "conditionalQuestions": ["android_studio"]
    },
    "desktop_windows": {
      "description": "Windows desktop application",
      "tech": "Electron, Tauri, .NET/WPF",
      "implies": ["native_features"],
      "conditionalQuestions": ["win32_or_uwp"]
    },
    "desktop_mac": {
      "description": "macOS desktop application",
      "tech": "Electron, SwiftUI, Tauri",
      "implies": ["apple_developer"],
      "conditionalQuestions": ["xcode_required"]
    },
    "desktop_linux": {
      "description": "Linux desktop application",
      "tech": "Electron, Tauri, GTK",
      "implies": ["cross_distro"],
      "conditionalQuestions": []
    },
    "public_api": {
      "description": "Public API for third-party developers",
      "tech": "REST, GraphQL",
      "implies": ["api_documentation", "rate_limiting", "api_versioning", "developer_portal"],
      "conditionalQuestions": ["api_auth_method", "webhooks_needed"]
    }
  },

  # ============================================================================
  # 3. FRONTEND ARCHITECTURE - Rendering strategies and patterns
  # ============================================================================
  "frontendArchitecture": {
    "static_pages": {
      "description": "Pure HTML/CSS - no dynamic logic",
      "pros": ["extremely fast", "cheap", "simple"],
      "cons": ["no interaction", "no dynamic data"],
      "useCases": ["landing pages", "documentation", "blogs"],
      "stack": ["HTML", "CSS", "CDN"],
      "when": "Site is mostly static with no interactivity"
    },
    "mvc": {
      "description": "Server renders HTML - backend combines data and template",
      "pros": ["simple", "easy backend control"],
      "cons": ["tight coupling", "page reloads", "poor scalability"],
      "useCases": ["Traditional web apps"],
      "stack": ["Django", "Ruby on Rails", "Laravel", "ASP.NET"],
      "when": "Simple app, tight team, server-rendered pages OK"
    },
    "spa": {
      "description": "Frontend is full application, backend only serves APIs",
      "pros": ["very interactive", "scalable UI", "rich dashboards"],
      "cons": ["heavy JS", "slow first load", "poor SEO"],
      "useCases": ["SaaS dashboards", "internal tools", "admin panels"],
      "stack": ["React", "Vue", "Angular", "Svelte"],
      "when": "High interactivity, dashboards, no SEO needed"
    },
    "ssr": {
      "description": "Server-side rendering - pages generated on request",
      "pros": ["fast initial load", "good SEO"],
      "cons": ["server load", "more infrastructure"],
      "useCases": ["Marketplaces", "eCommerce", "SaaS with SEO"],
      "stack": ["Next.js", "Nuxt.js", "SvelteKit"],
      "when": "SEO required + interactive"
    },
    "ssg": {
      "description": "Static site generation - pages built at compile time",
      "pros": ["fastest"],
      "cons": ["content updates require rebuild"],
      "useCases": ["blogs", "marketing pages"],
      "stack": ["Next.js", "Astro", "Hugo", "Gatsby"],
      "when": "Content rarely changes, max performance needed"
    },
    "isr": {
      "description": "Incremental static regeneration - static + periodic rebuilds",
      "pros": ["dynamic updates", "fast CDN"],
      "useCases": ["product catalogs"],
      "stack": ["Next.js ISR"],
      "when": "Content updates occasionally, want CDN speed"
    },
    "bff": {
      "description": "Backend for Frontend - dedicated API layer per client",
      "benefits": ["optimized responses", "frontend independence", "easier auth"],
      "downsides": ["more infrastructure", "single failure point"],
      "useCases": ["mobile app + web app + admin"],
      "when": "Multiple client types (web + mobile + etc)"
    },
    "modular_monolith": {
      "description": "Large SPA organized into domains",
      "benefits": ["maintainable", "scalable", "clear boundaries"],
      "drawbacks": ["build times grow", "boundaries hard to enforce"],
      "useCases": ["10-100 developers"],
      "structure": "src/domains/, src/shared/",
      "when": "Medium team, need organization without microservices complexity"
    },
    "microfrontends": {
      "description": "Multiple independent frontends assembled together",
      "benefits": ["huge scaling", "independent deploys"],
      "drawbacks": ["heavy complexity", "performance overhead"],
      "usedBy": ["Amazon", "Spotify", "enterprise SaaS"],
      "when": "200+ developers, separate teams owning separate features"
    }
  },

